{
  "ReverseProxy": {
    "Routes": {
      "auth": {
        "ClusterId": "authCluster",
        "Match": {
          "Path": "/auth/{**catch-all}"
        },
        "AuthorizationPolicy": "authenticated"
      },
      "workshift": {
        "ClusterId": "workshiftCluster",
        "Match": {
          "Path": "/workshift/{**catch-all}"
        },
        "AuthorizationPolicy": "authenticated"
      },
      "booking": {
        "ClusterId": "bookingCluster",
        "Match": {
          "Path": "/booking/{**catch-all}"
        },
        "AuthorizationPolicy": "authenticated"

      },
      "profile": {
        "ClusterId": "profileCluster",
        "Match": {
          "Path": "/profile/{**catch-all}"
        },
        "AuthorizationPolicy": "authenticated"
      }
    }
  }
}