{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information",
      "Yarp.ReverseProxy": "Debug"
    }
  },
  "ServiceHealthUrls": {
    "Auth": "http://localhost:5091/health",
    "Profile": "https://localhost:7294/health",
    "Booking": "https://localhost:7213/health",
    "Workshift": "https://localhost:7103/health"
  },
  "ReverseProxy": {
    "Clusters": {
      "authCluster": {
        "Destinations": {
          "authService": {
            "Address": "http://localhost:5091/"
          }
        }
      },
      "profileCluster": {
        "Destinations": {
          "profileService": {
            "Address": "https://localhost:7294/"
          }
        }
      },
      "bookingCluster": {
        "Destinations": {
          "bookingService": {
            "Address": "https://localhost:7213/"
          }
        }
      },
      "workshiftCluster": {
        "Destinations": {
          "workshiftService": {
            "Address": "https://localhost:7103/"
          }
        }
      }
    },
    "Routes": {
      "auth": {
        "ClusterId": "authCluster",
        "Match": {
          "Path": "/auth/{**catch-all}"
        }
      },
      "auth-api": {
        "ClusterId": "authCluster",
        "Match": {
          "Path": "/api/auth/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/api" }
        ]
      },

      "profile": {
        "ClusterId": "profileCluster",
        "Match": {
          "Path": "/profile/{**catch-all}"
        },
        "AuthorizationPolicy": "authenticated"
      },
      "profile-api": {
        "ClusterId": "profileCluster",
        "Match": {
          "Path": "/api/profile/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/api" }
        ],
        "AuthorizationPolicy": "authenticated"
      },

      "booking": {
        "ClusterId": "bookingCluster",
        "Match": {
          "Path": "/booking/{**catch-all}"
        },
        "AuthorizationPolicy": "authenticated"
      },
      "booking-api": {
        "ClusterId": "bookingCluster",
        "Match": {
          "Path": "/api/booking/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/api" }
        ],
        "AuthorizationPolicy": "authenticated"
      },

      "workshift": {
        "ClusterId": "workshiftCluster",
        "Match": {
          "Path": "/workshift/{**catch-all}"
        },
        "AuthorizationPolicy": "authenticated"
      },
      "workshift-api": {
        "ClusterId": "workshiftCluster",
        "Match": {
          "Path": "/api/workshift/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/api" }
        ],
        "AuthorizationPolicy": "authenticated"
      }
    }
  }
}

